{
  "name": "book-a-prison-visit-staff-ui",
  "version": "0.0.1",
  "description": "Book A Prison Visit Staff Ui",
  "repository": "git@github.com:ministryofjustice/book-a-prison-visit-staff-ui.git",
  "license": "MIT",
  "scripts": {
    "prepare": "hmpps-precommit-hooks-prepare",
    "copy-views": "cp -R server/views dist/server/",
    "compile-sass": "sass --quiet-deps --no-source-map --load-path=node_modules/govuk-frontend/dist --load-path=node_modules/@ministryofjustice/frontend --load-path=. ./assets/sass/application.scss:./assets/stylesheets/application.css --style compressed",
    "watch-ts": "tsc -w",
    "watch-views": "nodemon --watch server/views -e html,njk -x npm run copy-views",
    "watch-node": "DEBUG=gov-starter-server* nodemon -r dotenv/config --watch dist/ dist/server.js | bunyan -o short",
    "watch-sass": "npm run compile-sass -- --watch",
    "build": "npm run compile-sass && tsc && npm run copy-views",
    "start": "node $NODE_OPTIONS dist/server.js | bunyan -o short",
    "start:dev": "concurrently -k -p \"[{name}]\" -n \"Views,TypeScript,Node,Sass\" -c \"yellow.bold,cyan.bold,green.bold,blue.bold\" \"npm run watch-views\" \"npm run watch-ts\" \"npm run watch-node\" \"npm run watch-sass\"",
    "start-feature": "export $(cat feature.env) && node $NODE_DEBUG_OPTION dist/server.js | bunyan -o short",
    "watch-node-feature": "export $(cat feature.env) && nodemon --watch dist/ $NODE_DEBUG_OPTION dist/server.js | bunyan -o short",
    "start-feature:dev": "concurrently -k -p \"[{name}]\" -n \"Views,TypeScript,Node,Sass\" -c \"yellow.bold,cyan.bold,green.bold,blue.bold\" \"npm run watch-views\" \"npm run watch-ts\" \"npm run watch-node-feature\" \"npm run watch-sass\"",
    "lint": "eslint . --cache --max-warnings 0",
    "lint-fix": "eslint . --fix",
    "typecheck": "tsc && tsc -p integration_tests",
    "test": "jest",
    "test:ci": "jest --runInBand --coverage",
    "security_audit": "npx audit-ci --config audit-ci.json",
    "int-test": "npx playwright test",
    "int-test-ui": "npx playwright test --ui",
    "int-test-init:ci": "npx playwright install",
    "clean": "rm -rf dist build node_modules stylesheets",
    "setup": "npm ci && hmpps-npm-script-run-allowlist"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1080.0",
    "@axe-core/playwright": "4.12.1",
    "@ministryofjustice/frontend": "^9.0.0",
    "@ministryofjustice/hmpps-auth-clients": "3.0.0",
    "@ministryofjustice/hmpps-azure-telemetry": "1.0.2",
    "@ministryofjustice/hmpps-connect-dps-components": "^6.2.1",
    "@ministryofjustice/hmpps-monitoring": "^2.1.0",
    "@ministryofjustice/hmpps-rest-client": "^2.2.0",
    "agentkeepalive": "^4.6.0",
    "bunyan": "^1.8.15",
    "bunyan-format": "^0.2.1",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-redis": "^9.0.0",
    "csrf-sync": "^4.2.1",
    "date-fns": "^4.4.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "govuk-frontend": "^6.3.0",
    "helmet": "^8.2.0",
    "http-errors": "^2.0.1",
    "jwt-decode": "^4.0.0",
    "libphonenumber-js": "^1.13.8",
    "nocache": "^4.0.0",
    "nunjucks": "^3.2.4",
    "passport": "^0.7.0",
    "passport-oauth2": "^1.8.0",
    "redis": "^6.1.0",
    "superagent": "^10.3.0"
  },
  "devDependencies": {
    "@aws-sdk/types": "^3.973.15",
    "@ministryofjustice/eslint-config-hmpps": "^1.0.3",
    "@ministryofjustice/hmpps-npm-script-allowlist": "0.0.6",
    "@ministryofjustice/hmpps-precommit-hooks": "3.0.1",
    "@playwright/test": "^1.61.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/bunyan": "^1.8.11",
    "@types/bunyan-format": "^0.2.9",
    "@types/compression": "^1.8.1",
    "@types/connect-flash": "0.0.40",
    "@types/express-session": "^1.19.0",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.13.3",
    "@types/nunjucks": "^3.2.6",
    "@types/passport": "^1.0.17",
    "@types/passport-oauth2": "^1.8.0",
    "@types/superagent": "^8.1.10",
    "@types/supertest": "^7.2.0",
    "audit-ci": "^7.1.0",
    "axe-core": "^4.12.1",
    "cheerio": "^1.2.0",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^17.0.0",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^17.0.8",
    "nock": "^14.0.16",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "prettier-plugin-jinja-template": "^2.2.0",
    "sass": "^1.101.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@opentelemetry/core": "2.9.0",
    "brace-expansion": "5.0.7",
    "shell-quote": "1.9.0"
  }
}
